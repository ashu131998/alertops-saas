NODE_ENV=production
PORT=4000

# Uses existing esp-iot postgres container — hostname resolves via shared Docker network
DATABASE_URL=postgresql://alertops:AlertOpsPg2026x9z@esp-iot-postgres-1:5432/industrial_saas

# Generate strong secrets: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_32_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_32_CHARS_MIN_DIFFERENT
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Your AlertOps web domain
CORS_ORIGINS=https://alertops.duckdns.org

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

LOG_LEVEL=info

EXPO_ACCESS_TOKEN=
